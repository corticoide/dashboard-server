JWT_SECRET=change-me-to-a-long-random-string
DB_PATH=./data/serverdash.db
CERT_FILE=./certs/cert.pem
KEY_FILE=./certs/key.pem
PORT=8443
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
# ALLOWED_ORIGINS: The LAN IP is added automatically at startup.
# Only set this if you need to override or add extra origins manually.
# Example for a fixed LAN IP:
# ALLOWED_ORIGINS=["https://localhost:8443","https://192.168.1.100:8443"]
ALLOWED_ORIGINS=["https://localhost:8443"]
ALERTS_RETENTION_DAYS=90
