{
  "name": "serverdash-frontend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node --max-old-space-size=2048 node_modules/.bin/vite build",
    "build:safe": "timeout 120 node --max-old-space-size=2048 node_modules/.bin/vite build",
    "postinstall": "node scripts/copy-monaco.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@guolao/vue-monaco-editor": "^1.6.0",
    "@primeuix/themes": "^2.0.3",
    "@primevue/themes": "^4.5.4",
    "axios": "^1.7.0",
    "chart.js": "^4.5.1",
    "pinia": "^2.2.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^25.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
